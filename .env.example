# Backend
PORT=5000
AWS_REGION=us-east-1
SQS_QUEUE_URL=

# Docker image references for CI/CD
AWS_ACCOUNT_ID=123456789012
ECR_REPO_BACKEND=helpdesk-backend
ECR_REPO_FRONTEND=helpdesk-frontend
ECR_REPO_WORKER=helpdesk-worker
